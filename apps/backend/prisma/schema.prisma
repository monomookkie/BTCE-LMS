generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===== Auth & User =====

model User {
  id                String    @id @default(cuid())
  employeeId        String?   @unique
  name              String
  email             String    @unique
  password          String
  role              Role      @default(USER)
  position          String?
  department        String? // free-text — ไม่ใช่ relational model เดิมที่ลบใน REFACTOR-1
                            // กรอกได้แค่ตอน self-register (required ที่นั่น); ช่องทางอื่นไม่ set
  avatarKey         String?   // key ใน Cloudinary (ไม่เก็บ base64)
  isActive          Boolean   @default(true)
  mustChangePassword Boolean  @default(false) // บังคับเปลี่ยนรหัสหลังล็อกอินแรก
  language          String    @default("en")  // 'en' | 'th' — user language preference
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? // soft delete

  enrollments          Enrollment[]
  externalCertificates ExternalCertificate[]
  refreshTokens        RefreshToken[]
  consents             Consent[]
  notifications        Notification[]

  @@index([email])
  @@index([deletedAt])
}

enum Role {
  ADMIN
  USER
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    // hash ของ token — ไม่เก็บ plaintext
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
}

// ===== Course & Material =====

model Course {
  id            String       @id @default(cuid())
  titleEn       String
  titleTh       String?
  categoryEn    String
  categoryTh    String?
  descriptionEn String?      @db.Text
  descriptionTh String?      @db.Text
  status        CourseStatus @default(DRAFT)
  durationMin  Int?
  passScore    Int          @default(80)
  expiryMonths    Int? // ต้องต่ออายุทุกกี่เดือน (null = ไม่หมดอายุ)
  allowSelfEnroll Boolean  @default(false) // อนุญาตให้ USER ลงทะเบียนเอง
  createdById     String?
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  materials   Material[]
  quiz        Quiz?
  enrollments Enrollment[]

  @@index([status, deletedAt])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Material {
  id        String       @id @default(cuid())
  courseId  String
  type      MaterialType
  titleEn   String
  titleTh   String?
  fileKey   String? // Cloudinary public_id
  url       String? // external link/video URL
  mimeType  String?
  sizeBytes Int?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  deletedAt DateTime? // soft delete — ไฟล์จริงยังอยู่ใน Cloudinary รอ cleanup job

  course Course @relation(fields: [courseId], references: [id])

  @@index([courseId, order])
  @@index([courseId, deletedAt])
}

enum MaterialType {
  PDF
  VIDEO
  LINK
  IMAGE
  DOC
}

// ===== Quiz Engine =====

model Quiz {
  id          String    @id @default(cuid())
  courseId    String    @unique
  titleEn     String
  titleTh     String?
  maxAttempts Int? // null = ไม่จำกัด
  shuffle     Boolean   @default(true)
  deletedAt   DateTime?

  course    Course        @relation(fields: [courseId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id        String    @id @default(cuid())
  quizId    String
  textEn    String    @db.Text
  textTh    String?   @db.Text
  order     Int       @default(0)
  deletedAt DateTime?

  quiz    Quiz     @relation(fields: [quizId], references: [id])
  options Option[]

  @@index([quizId, order])
}

model Option {
  id         String  @id @default(cuid())
  questionId String
  textEn     String
  textTh     String?
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  passed    Boolean
  answers   Json // { questionId: optionId } เก็บไว้ทบทวน
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id])

  @@index([quizId, userId])
}

// ===== Enrollment & Certificate =====

model Enrollment {
  id                 String       @id @default(cuid())
  userId             String
  courseId           String
  status             EnrollStatus @default(IN_PROGRESS)
  progress           Int          @default(0) // 0-100
  completedMaterials Json         @default("[]") // string[] ของ materialId
  assignedAt         DateTime     @default(now())
  dueAt              DateTime?
  completedAt        DateTime?
  createdAt          DateTime     @default(now())
  deletedAt          DateTime? // soft delete — unique ตรวจที่ app level เพื่อรองรับ re-enroll หลัง cancel

  user        User         @relation(fields: [userId], references: [id])
  course      Course       @relation(fields: [courseId], references: [id])
  materialProgress MaterialProgress[]

  // unique constraint อยู่ที่ service layer (ตรวจ deletedAt: null) — ไม่ใช่ DB
  // เพราะ MySQL ไม่รองรับ partial/filtered unique index
  @@index([userId, courseId])
  @@index([userId, status, deletedAt])
  @@index([courseId, status, deletedAt])
}

// Tier 2/3 anti-cheat: track ว่าเปิดสื่อการเรียนจริงหรือยัง + ดูวิดีโอไปถึงไหน
// ใช้ gate ก่อนอนุญาต mark-material-complete (ดู markMaterialComplete)
model MaterialProgress {
  id             String    @id @default(cuid())
  enrollmentId   String
  materialId     String
  openedAt       DateTime? // ตั้งครั้งแรกที่เปิดเท่านั้น — เปิดซ้ำไม่ reset
  watchedPercent Int       @default(0) // 0-100, เก็บค่าสูงสุดที่เคยดูถึง กันไถ progress ถอยหลัง
  durationSeconds Int? // ความยาววิดีโอ (client รายงานมา, lock ค่าแรกที่ได้รับ) ใช้คำนวณ time-ceiling กัน watchedPercent ปลอม
  embedFailed    Boolean   @default(false) // YouTube iframe โหลดไม่สำเร็จ (network/CSP/timeout) — fallback เป็น time-gate แบบ LINK แทน percent-gate
  lastProgressAt DateTime?
  createdAt      DateTime  @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@unique([enrollmentId, materialId])
}

enum EnrollStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

// ใบรับรองภายนอกที่ผู้ใช้อัปโหลดเอง (จากองค์กรภายนอก)
model ExternalCertificate {
  id        String    @id @default(cuid())
  userId    String
  title     String
  issuer    String
  issuedAt  DateTime
  expiresAt DateTime?
  fileKey   String? // อัปโหลดขึ้น storage — ไม่เก็บ base64
  mimeType  String? // MIME type ของไฟล์ที่อัปโหลด — ใช้กำหนด Cloudinary resource_type ตอนสร้าง signed URL
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deletedAt])
}

// ===== Training Log (offline) =====

model TrainingLog {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  trainer     String
  location    String?
  durationMin Int?
  type        String?
  topics      String?  @db.Text
  fileKey     String? // Cloudinary public_id
  createdAt   DateTime @default(now())

  attendees TrainingAttendee[]
}

model TrainingAttendee {
  trainingId String
  userId     String

  training TrainingLog @relation(fields: [trainingId], references: [id])

  @@id([trainingId, userId])
}

// ===== Announcement =====

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String             @id @default(cuid())
  titleEn     String
  titleTh     String?
  contentEn   String             @db.Text
  contentTh   String?            @db.Text
  type        String             @default("INFO")
  status      AnnouncementStatus @default(DRAFT)
  fileKey     String?
  link        String?
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@index([status, deletedAt, createdAt])
}

// ===== Compliance =====

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // userId ที่ทำ action (null = system)
  action     String // เช่น "USER_CREATE", "CERT_ISSUE", "USER_LOGIN"
  targetType String? // "User", "Course", "Certificate"...
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  type      String // "PDPA_BASIC", "MARKETING"
  granted   Boolean
  version   String // เวอร์ชัน privacy policy เช่น "1.0"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}
