generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===== Auth & User =====

model User {
  id                String    @id @default(cuid())
  employeeId        String?   @unique
  name              String
  email             String    @unique
  password          String
  role              Role      @default(USER)
  positionId        String?
  department        String? // free-text — ไม่ใช่ relational model เดิมที่ลบใน REFACTOR-1
                            // กรอกได้แค่ตอน self-register (required ที่นั่น); ช่องทางอื่นไม่ set
  avatarKey         String?   // key ใน Cloudinary (ไม่เก็บ base64)
  isActive          Boolean   @default(true)
  mustChangePassword Boolean  @default(false) // บังคับเปลี่ยนรหัสหลังล็อกอินแรก
  language          String    @default("en")  // 'en' | 'th' — user language preference
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? // soft delete

  position             Position?              @relation(fields: [positionId], references: [id])
  enrollments          Enrollment[]
  externalCertificates ExternalCertificate[]
  refreshTokens        RefreshToken[]
  consents             Consent[]

  @@index([email])
  @@index([deletedAt])
  @@index([positionId])
}

// ===== Position (2C-1) =====
// structured lookup table แทน User.position free-text เดิม — ให้ course
// access model (2C-2) ผูก position ได้แม่นยำ (ไม่พึ่ง string matching)
model Position {
  id           String    @id @default(cuid())
  nameEn       String
  nameTh       String?
  // true = สงวนไว้สำหรับ system/admin ใช้เท่านั้น (เช่น "Administrator") — ไม่ขึ้นให้เลือกในหน้า
  // self-register สาธารณะ (GET /positions filter ออก) แต่ ADMIN ยัง assign ให้ user อื่นได้ปกติผ่าน
  // /positions/admin — ไม่มี UI ให้ admin สร้าง/แก้ flag นี้เอง (ตั้งใจ กันสร้างเพิ่มเรื่อยๆ)
  isSystemOnly Boolean   @default(false)
  // ลำดับแสดงผลใน dropdown (self-register, Manage Positions) — ต่ำไปสูง, เท่ากันตัดสินด้วย nameEn
  // ไม่มี UI ให้ admin แก้เอง (ตั้งใจ เหมือน isSystemOnly) แก้ได้ผ่าน backend/seed เท่านั้น
  sortOrder    Int       @default(0)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users User[]
  courses CoursePosition[]

  @@unique([nameEn])
  @@index([deletedAt])
}

enum Role {
  ADMIN
  USER
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    // hash ของ token — ไม่เก็บ plaintext
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
}

// ===== Course & Material =====

model Course {
  id            String       @id @default(cuid())
  titleEn       String
  titleTh       String?
  categoryEn    String
  categoryTh    String?
  descriptionEn String?      @db.Text
  descriptionTh String?      @db.Text
  status        CourseStatus @default(DRAFT)
  enrollmentCloseAt DateTime? // ปิดรับลงทะเบียนใหม่หลังวันนี้ (null = ไม่มีกำหนด) — ผู้ที่ลงแล้วเรียนต่อได้ตามปกติ
  paperSavingSheets Int? // จำนวนกระดาษที่ประหยัดได้ต่อผู้เรียน 1 คน (null = ไม่แสดงข้อความ)
  accessType   CourseAccessType @default(PUBLIC) // 2C-2: POSITION_BASED (บังคับ) | PUBLIC (สมัครใจ) — แทน allowSelfEnroll เดิม
  createdById     String?
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  materials   Material[]
  quiz        Quiz?
  survey      Survey?
  enrollments Enrollment[]
  positions   CoursePosition[]

  @@index([status, deletedAt])
}

enum CourseAccessType {
  POSITION_BASED
  PUBLIC
}

// ===== CoursePosition (2C-2) =====
// many-to-many Course <-> Position — เฉพาะ course ที่ accessType = POSITION_BASED เท่านั้นที่ควรมี row
model CoursePosition {
  id         String   @id @default(cuid())
  courseId   String
  positionId String
  createdAt  DateTime @default(now())

  course   Course   @relation(fields: [courseId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  @@unique([courseId, positionId])
  @@index([positionId])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Material {
  id        String       @id @default(cuid())
  courseId  String
  type      MaterialType
  titleEn   String
  titleTh   String?
  fileKey   String? // Cloudinary public_id
  url       String? // external link/video URL
  mimeType  String?
  sizeBytes Int?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  deletedAt DateTime? // soft delete — ไฟล์จริงยังอยู่ใน Cloudinary รอ cleanup job

  course Course @relation(fields: [courseId], references: [id])

  @@index([courseId, order])
  @@index([courseId, deletedAt])
}

enum MaterialType {
  PDF
  VIDEO
  LINK
  IMAGE
  DOC
}

// ===== Quiz Engine =====

model Quiz {
  id          String    @id @default(cuid())
  courseId    String    @unique
  titleEn     String
  titleTh     String?
  // เกณฑ์ผ่าน = ต้องตอบถูกกี่ข้อ (จำนวนเต็ม ไม่ใช่ %) — เปลี่ยนจาก passScore% เดิมเพื่อให้ admin
  // ตั้งค่าง่ายขึ้น ("ต้องตอบถูก 8 จาก 10 ข้อ" แทน "ต้องได้ 80%") และตัด rounding ambiguity ตอนเกรด
  passRequiredCount Int       @default(1)
  maxAttempts Int? // null = ไม่จำกัด
  shuffle     Boolean   @default(true)
  deletedAt   DateTime?

  course    Course        @relation(fields: [courseId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id        String    @id @default(cuid())
  quizId    String
  textEn    String    @db.Text
  textTh    String?   @db.Text
  order     Int       @default(0)
  deletedAt DateTime?

  quiz    Quiz     @relation(fields: [quizId], references: [id])
  options Option[]

  @@index([quizId, order])
}

model Option {
  id         String  @id @default(cuid())
  questionId String
  textEn     String
  textTh     String?
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  passed    Boolean
  answers   Json // { questionId: optionId } เก็บไว้ทบทวน
  // ตอบถูกกี่ข้อ/เต็มกี่ข้อ — snapshot ตอนสอบจริง (nullable: attempt เก่าก่อน migration นี้ไม่มีค่า
  // แสดง "—" แทน ไม่ backfill เดาย้อนหลัง เพราะข้อสอบอาจถูกแก้/ลบไปแล้วหลังจากสอบทำให้คำนวณผิด)
  correctCount    Int?
  totalQuestions  Int?
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id])

  @@index([quizId, userId])
}

// ===== Survey (post-course feedback) =====
// Optional per course (ไม่บังคับเหมือน Quiz) — ถ้ามี survey ต้องตอบก่อน COMPLETED (2B)

model Survey {
  id        String    @id @default(cuid())
  courseId  String    @unique
  deletedAt DateTime?

  course    Course           @relation(fields: [courseId], references: [id])
  questions SurveyQuestion[]
  responses SurveyResponse[]
}

enum SurveyQuestionType {
  RATING
  TEXT
}

model SurveyQuestion {
  id        String             @id @default(cuid())
  surveyId  String
  type      SurveyQuestionType
  textEn    String             @db.Text
  textTh    String?            @db.Text
  order     Int                @default(0)
  deletedAt DateTime?

  survey Survey @relation(fields: [surveyId], references: [id])

  @@index([surveyId, order])
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  userId    String
  answers   Json // { [questionId]: number (1-5, RATING) | string (TEXT) }
  createdAt DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])

  @@unique([surveyId, userId]) // ตอบได้ครั้งเดียว — ไม่ retake เหมือน quiz
}

// ===== Enrollment & Certificate =====

model Enrollment {
  id                 String       @id @default(cuid())
  userId             String
  courseId           String
  status             EnrollStatus @default(IN_PROGRESS)
  progress           Int          @default(0) // 0-100
  completedMaterials Json         @default("[]") // string[] ของ materialId
  isMandatory        Boolean      @default(false) // 2C-3: snapshot จาก course.accessType ตอน enroll — POSITION_BASED=true, PUBLIC=false
  // จำนวนครั้งที่ ADMIN ให้สิทธิ์สอบ quiz เพิ่มเป็นกรณีพิเศษ (เช่น สอบไม่ผ่านครบ maxAttempts แต่อยากให้
  // โอกาสอีก) — บวกเพิ่มจาก quiz.maxAttempts เฉพาะ enrollment นี้ ไม่กระทบ user คนอื่น ไม่มี UI ให้ user แก้เอง
  bonusQuizAttempts  Int          @default(0)
  assignedAt         DateTime     @default(now())
  dueAt              DateTime?
  completedAt        DateTime?
  createdAt          DateTime     @default(now())
  deletedAt          DateTime? // soft delete — unique ตรวจที่ app level เพื่อรองรับ re-enroll หลัง cancel

  user        User         @relation(fields: [userId], references: [id])
  course      Course       @relation(fields: [courseId], references: [id])
  materialProgress MaterialProgress[]

  // unique constraint อยู่ที่ service layer (ตรวจ deletedAt: null) — ไม่ใช่ DB
  // เพราะ MySQL ไม่รองรับ partial/filtered unique index
  @@index([userId, courseId])
  @@index([userId, status, deletedAt])
  @@index([courseId, status, deletedAt])
}

// Tier 2/3 anti-cheat: track ว่าเปิดสื่อการเรียนจริงหรือยัง + ดูวิดีโอไปถึงไหน
// ใช้ gate ก่อนอนุญาต mark-material-complete (ดู markMaterialComplete)
model MaterialProgress {
  id             String    @id @default(cuid())
  enrollmentId   String
  materialId     String
  openedAt       DateTime? // ตั้งครั้งแรกที่เปิดเท่านั้น — เปิดซ้ำไม่ reset
  watchedPercent Int       @default(0) // 0-100, เก็บค่าสูงสุดที่เคยดูถึง กันไถ progress ถอยหลัง
  durationSeconds Int? // ความยาววิดีโอ (client รายงานมา, lock ค่าแรกที่ได้รับ) ใช้คำนวณ time-ceiling กัน watchedPercent ปลอม
  embedFailed    Boolean   @default(false) // YouTube iframe โหลดไม่สำเร็จ (network/CSP/timeout) — fallback เป็น time-gate แบบ LINK แทน percent-gate
  // เวลาที่อยู่หน้าจริงสะสม (วินาที) — เพิ่มขึ้นทีละ heartbeat จาก client (นับเฉพาะตอน mount + tab visible)
  // ใช้แทน wall-clock diff จาก openedAt สำหรับ time-gate — ออกจากหน้าแล้วเวลาต้องหยุดนับ ไม่ใช่นับต่อ
  activeSeconds  Int       @default(0)
  lastProgressAt DateTime?
  createdAt      DateTime  @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@unique([enrollmentId, materialId])
}

enum EnrollStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

// ใบรับรองภายนอกที่ผู้ใช้อัปโหลดเอง (จากองค์กรภายนอก)
model ExternalCertificate {
  id        String    @id @default(cuid())
  userId    String
  title     String
  issuer    String
  issuedAt  DateTime
  expiresAt DateTime?
  fileKey   String? // อัปโหลดขึ้น storage — ไม่เก็บ base64
  mimeType  String? // MIME type ของไฟล์ที่อัปโหลด — ใช้กำหนด Cloudinary resource_type ตอนสร้าง signed URL
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deletedAt])
}

// ===== Announcement =====

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String             @id @default(cuid())
  titleEn     String
  titleTh     String?
  contentEn   String?            @db.Text
  contentTh   String?            @db.Text
  status      AnnouncementStatus @default(DRAFT)
  fileKey     String?
  fileMimeType String?
  link        String?
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@index([status, deletedAt, createdAt])
}

// ===== Compliance =====

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // userId ที่ทำ action (null = system)
  action     String // เช่น "USER_CREATE", "CERT_ISSUE", "USER_LOGIN"
  targetType String? // "User", "Course", "Certificate"...
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  type      String // "PDPA_BASIC", "MARKETING"
  granted   Boolean
  version   String // เวอร์ชัน privacy policy เช่น "1.0"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

