# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL="mysql://btec:btecpassword@localhost:3306/btec_lms"

# JWT — ใช้ openssl rand -base64 32 เพื่อ gen
JWT_SECRET=change-me-use-openssl-rand-base64-32
JWT_ACCESS_EXPIRES_IN=15m

# Refresh Token
REFRESH_TOKEN_SECRET=change-me-use-openssl-rand-base64-32
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=change-me-use-openssl-rand-base64-32

# CORS — origin ของ frontend
CORS_ORIGIN=http://localhost:5173

# Cloudinary (Phase 2)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed — admin account (บังคับเปลี่ยนหลังล็อกอินแรก)
SEED_ADMIN_EMAIL=admin@btec.rcthai.or.th
SEED_ADMIN_PASSWORD=change-me-immediately
